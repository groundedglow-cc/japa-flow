# EFE plugin: local session state (auto-generated, do not track)
/.efe/state/sessions/

# macOS noise
.DS_Store
**/.DS_Store

# Debug recordings (local-only, do not track)
debug-recordings/

# Audio files — stored on Alibaba Cloud OSS, local copy as cache only
audio/

# Node
node_modules/
.npm-cache/

# Monorepo package build output (regenerated by `npm -w <pkg> run build`)
packages/*/dist/
packages/*/node_modules/

# Local env (never commit secrets)
.env
.env.local

# Capacitor build output (regenerated by `npm run build:app`)
app-dist/

# App-side config containing secrets (Azure key bundled into App)
japaflow-config.local.js

# Capacitor native project caches
ios/App/Pods/
ios/App/build/
android/.gradle/
android/build/
android/app/build/
