{
  "name": "@japaflow/ai-assistant",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "JapaFlow 课内 AI 学习助手 - 悬浮入口 + 选句解释 + 侧边对话面板",
  "exports": {
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    },
    "./element": {
      "types": "./dist/element.d.ts",
      "import": "./dist/element.js"
    },
    "./protocol": {
      "types": "./dist/protocol.d.ts",
      "import": "./dist/protocol.js"
    },
    "./styles": "./dist/styles/index.css"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "vite build && node -e \"require('fs').mkdirSync('dist/styles',{recursive:true});require('fs').copyFileSync('src/styles/index.css','dist/styles/index.css')\"",
    "dev": "vite build --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/react": "^1.2.0",
    "preact": "^10.22.0"
  },
  "peerDependencies": {
    "react": "*",
    "react-dom": "*"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true },
    "react-dom": { "optional": true }
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0"
  }
}
